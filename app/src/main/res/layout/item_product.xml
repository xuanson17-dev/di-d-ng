<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@color/black_tech_card"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#2200E5FF"
    app:strokeWidth="1.5dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <ImageView
            android:id="@+id/imgProduct"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:scaleType="centerInside"
            android:src="@mipmap/ic_launcher"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvProductName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Product Name"
            android:textColor="@color/white_tech"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/imgProduct" />

        <TextView
            android:id="@+id/tvProductPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="0 VNĐ"
            android:textColor="@color/accent_tech"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvProductName" />

        <!-- Nút Thêm vào giỏ (Dùng cho màn Home) -->
        <ImageView
            android:id="@+id/btnAddToCart"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="6dp"
            android:background="@drawable/bg_accent_gradient"
            android:src="@android:drawable/ic_input_add"
            app:tint="@color/black_tech_bg"
            app:layout_constraintBottom_toBottomOf="@id/tvProductPrice"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvProductPrice" />

        <!-- Điều khiển số lượng (Dùng cho màn Cart - Ẩn mặc định) -->
        <LinearLayout
            android:id="@+id/layoutQuantity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/tvProductPrice"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvProductPrice">

            <Button
                android:id="@+id/btnMinus"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:text="-"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:textColor="@color/white_tech"
                app:strokeColor="#44FFFFFF" />

            <TextView
                android:id="@+id/tvQuantity"
                android:layout_width="30dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/white_tech"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnPlus"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:text="+"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:textColor="@color/white_tech"
                app:strokeColor="#44FFFFFF" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>