<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_tech_bg"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="40dp">

        <!-- MODERN COMPACT HEADER -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutTopHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="12dp"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvShopName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S-STORE TECH"
                android:textColor="@color/white_tech"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/imgProfile"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="@color/white_tech"
                app:layout_constraintBottom_toBottomOf="@id/tvShopName"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvShopName" />

            <ImageView
                android:id="@+id/imgCart"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="16dp"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/white_tech"
                app:layout_constraintBottom_toBottomOf="@id/tvShopName"
                app:layout_constraintEnd_toStartOf="@id/imgProfile"
                app:layout_constraintTop_toTopOf="@id/tvShopName" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- CLEAN SEARCH BAR -->
        <LinearLayout
            android:id="@+id/layoutSearchArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp"
            app:layout_constraintTop_toBottomOf="@id/layoutTopHeader">

            <EditText
                android:id="@+id/edtSearch"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input_field"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawablePadding="12dp"
                android:hint="Tìm kiếm thiết bị..."
                android:paddingHorizontal="16dp"
                android:textColor="@color/white_tech"
                android:textColorHint="@color/gray_tech_text"
                android:textSize="14sp" />

            <Spinner
                android:id="@+id/spnSort"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_accent_gradient"
                android:popupBackground="@color/black_tech_card" />
        </LinearLayout>

        <!-- SEAMLESS MODERN BANNER (No white borders, black tech background) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardBanner"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginHorizontal="20dp"
            app:cardBackgroundColor="@color/black_tech_card"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardMaxElevation="0dp"
            app:strokeWidth="0dp"
            app:cardUseCompatPadding="false"
            app:layout_constraintTop_toBottomOf="@id/layoutSearchArea">
            
            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/viewPagerBanner"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </com.google.android.material.card.MaterialCardView>

        <!-- CATEGORY SECTION -->
        <TextView
            android:id="@+id/tvCatTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="28dp"
            android:text="DANH MỤC"
            android:textColor="@color/accent_tech"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardBanner" />

        <HorizontalScrollView
            android:id="@+id/scrollCats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:scrollbars="none"
            app:layout_constraintTop_toBottomOf="@id/tvCatTitle">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp">

                <LinearLayout
                    android:id="@+id/catAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="10dp">
                    <ImageView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:padding="15dp"
                        android:background="@drawable/bg_input_field"
                        android:src="@android:drawable/ic_menu_today"
                        app:tint="@color/white_tech" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Tất cả"
                        android:textColor="@color/gray_tech_text"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/catIphone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="10dp">
                    <ImageView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:padding="15dp"
                        android:background="@drawable/bg_input_field"
                        android:src="@android:drawable/ic_menu_call"
                        app:tint="@color/white_tech" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="iPhone"
                        android:textColor="@color/gray_tech_text"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/catMacbook"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="10dp">
                    <ImageView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:padding="15dp"
                        android:background="@drawable/bg_input_field"
                        android:src="@android:drawable/ic_menu_gallery"
                        app:tint="@color/white_tech" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="MacBook"
                        android:textColor="@color/gray_tech_text"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/catCamera"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="10dp">
                    <ImageView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:padding="15dp"
                        android:background="@drawable/bg_input_field"
                        android:src="@android:drawable/ic_menu_camera"
                        app:tint="@color/white_tech" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Camera"
                        android:textColor="@color/gray_tech_text"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/catAccessories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="10dp">
                    <ImageView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:padding="15dp"
                        android:background="@drawable/bg_input_field"
                        android:src="@android:drawable/ic_menu_compass"
                        app:tint="@color/white_tech" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Phụ kiện"
                        android:textColor="@color/gray_tech_text"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- PRODUCT LIST SECTION -->
        <TextView
            android:id="@+id/tvProductTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="32dp"
            android:text="SẢN PHẨM MỚI"
            android:textColor="@color/accent_tech"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/scrollCats" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvProducts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:paddingHorizontal="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvProductTitle" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>