<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_tech_bg">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollDetail"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomAction"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="40dp">

            <!-- 1. Product Image Header -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutImageHeader"
                android:layout_width="match_parent"
                android:layout_height="380dp"
                android:background="@color/black_tech_card"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/imgDetail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerInside"
                    android:padding="40dp"
                    android:src="@mipmap/ic_launcher" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:background="@drawable/bg_login_gradient"
                    android:rotation="180"
                    app:layout_constraintBottom_toBottomOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Buttons Over Image -->
            <ImageView
                android:id="@+id/btnBackDetail"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="16dp"
                android:background="@drawable/bg_input_field"
                android:padding="10dp"
                android:src="@android:drawable/ic_menu_revert"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/white_tech" />

            <ImageView
                android:id="@+id/btnFavorite"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="16dp"
                android:background="@drawable/bg_input_field"
                android:padding="10dp"
                android:src="@android:drawable/btn_star_big_off"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/accent_tech" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                app:layout_constraintTop_toBottomOf="@id/layoutImageHeader">

                <!-- 2. Main Info -->
                <TextView
                    android:id="@+id/tvDetailName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Product Name"
                    android:textColor="@color/white_tech"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvDetailPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 VNĐ"
                        android:textColor="@color/accent_tech"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                    <RatingBar
                        style="?android:attr/ratingBarStyleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:isIndicator="true"
                        android:numStars="5"
                        android:rating="4.8"
                        android:progressTint="@color/accent_tech" />
                </LinearLayout>

                <!-- 3. Tech Specs Horizontal (Đã khôi phục) -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:scrollbars="none">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_input_field"
                            android:padding="12dp"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:layout_marginEnd="12dp">
                            <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_menu_manage" app:tint="@color/accent_tech" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CHIP" android:textColor="@color/gray_tech_text" android:textSize="10sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bionic/M3" android:textColor="@color/white_tech" android:textStyle="bold" android:textSize="11sp" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_input_field"
                            android:padding="12dp"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:layout_marginEnd="12dp">
                            <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_menu_gallery" app:tint="@color/accent_tech" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MÀN HÌNH" android:textColor="@color/gray_tech_text" android:textSize="10sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="120Hz OLED" android:textColor="@color/white_tech" android:textStyle="bold" android:textSize="11sp" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_input_field"
                            android:padding="12dp"
                            android:gravity="center"
                            android:orientation="vertical">
                            <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_lock_power_off" app:tint="@color/accent_tech" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PIN" android:textColor="@color/gray_tech_text" android:textSize="10sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Siêu bền" android:textColor="@color/white_tech" android:textStyle="bold" android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>
                </HorizontalScrollView>

                <!-- 4. Description -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:text="MÔ TẢ CHI TIẾT"
                    android:textColor="@color/accent_tech"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvDetailDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:lineSpacingExtra="5dp"
                    android:text="Nội dung mô tả sản phẩm..."
                    android:textColor="@color/gray_tech_text"
                    android:textSize="15sp" />

                <!-- 5. RELATED PRODUCTS -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:text="SẢN PHẨM TƯƠNG TỰ"
                    android:textColor="@color/accent_tech"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRelatedProducts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:paddingBottom="8dp" />

                <!-- 6. MODERN REVIEWS SECTION (Đã làm đẹp hơn) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ĐÁNH GIÁ SẢN PHẨM"
                        android:textColor="@color/accent_tech"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Xem tất cả (48)"
                        android:textColor="@color/gray_tech_text"
                        android:textSize="12sp" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@color/black_tech_card"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#1AFFFFFF"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Review Item 1 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                app:cardCornerRadius="18dp"
                                app:cardBackgroundColor="#222222"
                                app:cardElevation="0dp">
                                <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:src="@android:drawable/ic_menu_myplaces" android:padding="8dp" app:tint="@color/accent_tech"/>
                            </com.google.android.material.card.MaterialCardView>
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hoàng Nam" android:textColor="@color/white_tech" android:textStyle="bold" android:textSize="14sp" />
                                <RatingBar style="?android:attr/ratingBarStyleSmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:rating="5" android:progressTint="@color/accent_tech" android:isIndicator="true"/>
                            </LinearLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2 ngày trước" android:textColor="@color/gray_tech_text" android:textSize="11sp" />
                        </LinearLayout>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Sản phẩm đóng gói rất cẩn thận, giao hàng siêu nhanh. Sẽ ủng hộ S-Store dài dài!" android:textColor="@color/gray_tech_text" android:textSize="14sp" />

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="16dp" android:background="#1AFFFFFF" />

                        <!-- Review Item 2 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                app:cardCornerRadius="18dp"
                                app:cardBackgroundColor="#222222"
                                app:cardElevation="0dp">
                                <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:src="@android:drawable/ic_menu_myplaces" android:padding="8dp" app:tint="@color/accent_tech"/>
                            </com.google.android.material.card.MaterialCardView>
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Minh Thư" android:textColor="@color/white_tech" android:textStyle="bold" android:textSize="14sp" />
                                <RatingBar style="?android:attr/ratingBarStyleSmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:rating="4" android:progressTint="@color/accent_tech" android:isIndicator="true"/>
                            </LinearLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1 tuần trước" android:textColor="@color/gray_tech_text" android:textSize="11sp" />
                        </LinearLayout>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Máy dùng mượt, thiết kế đẹp, màu cyan rất sang trọng. Tuy nhiên pin hơi nhanh hết một chút." android:textColor="@color/gray_tech_text" android:textSize="14sp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Actions -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutBottomAction"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:background="@color/black_tech_card"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddToCart"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                android:text="GIỎ HÀNG"
                android:textColor="@color/accent_tech"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:strokeColor="@color/accent_tech"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBuyNow"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_weight="1.5"
                android:text="MUA NGAY"
                android:textColor="@color/black_tech_bg"
                android:background="@drawable/bg_accent_gradient"
                app:backgroundTint="@null"
                app:cornerRadius="12dp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>