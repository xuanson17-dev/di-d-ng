<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardBackgroundColor="@color/black_tech_card"
    app:cardCornerRadius="24dp"
    app:strokeColor="@color/accent_tech"
    app:strokeWidth="1.5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_input_field"
            android:padding="20dp"
            android:src="@android:drawable/checkbox_on_background"
            app:tint="@color/accent_tech" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="ĐẶT HÀNG THÀNH CÔNG"
            android:textColor="@color/white_tech"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Đơn hàng của bạn đã được tiếp nhận.\nCảm ơn bạn đã tin tưởng S-Store Tech!"
            android:textColor="@color/gray_tech_text"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinueShopping"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:text="TIẾP TỤC MUA SẮM"
            android:textColor="@color/black_tech_bg"
            android:textStyle="bold"
            android:background="@drawable/bg_accent_gradient"
            app:backgroundTint="@null"
            app:cornerRadius="16dp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>