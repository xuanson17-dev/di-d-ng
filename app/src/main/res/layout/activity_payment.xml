<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_tech_bg">

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutHeaderPayment"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/black_tech_bg"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBackPayment"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="12dp"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_revert"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white_tech" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="THANH TOÁN"
            android:textColor="@color/white_tech"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1AFFFFFF"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomPayment"
        app:layout_constraintTop_toBottomOf="@id/layoutHeaderPayment">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Section: Địa chỉ -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_menu_mylocation"
                    app:tint="@color/accent_tech" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="ĐỊA CHỈ GIAO HÀNG"
                    android:textColor="@color/accent_tech"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/black_tech_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#1AFFFFFF"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <EditText
                        android:id="@+id/edtPhone"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_input_field"
                        android:hint="Số điện thoại liên lạc"
                        android:inputType="phone"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/white_tech"
                        android:textColorHint="@color/gray_tech_text"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/edtEmailPayment"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_input_field"
                        android:hint="Email nhận hóa đơn"
                        android:inputType="textEmailAddress"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/white_tech"
                        android:textColorHint="@color/gray_tech_text"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/edtAddress"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_input_field"
                        android:gravity="top"
                        android:hint="Địa chỉ nhận hàng chi tiết..."
                        android:inputType="textPostalAddress|textMultiLine"
                        android:padding="16dp"
                        android:textColor="@color/white_tech"
                        android:textColorHint="@color/gray_tech_text"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section: Phương thức thanh toán -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_menu_agenda"
                    app:tint="@color/accent_tech" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="PHƯƠNG THỨC THANH TOÁN"
                    android:textColor="@color/accent_tech"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />
            </LinearLayout>

            <RadioGroup
                android:id="@+id/rgPaymentMethod"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <RadioButton
                    android:id="@+id/rbCOD"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_input_field"
                    android:buttonTint="@color/accent_tech"
                    android:checked="true"
                    android:paddingHorizontal="12dp"
                    android:text="Tiền mặt khi nhận hàng (COD)"
                    android:textColor="@color/white_tech"
                    android:textSize="15sp" />

                <RadioButton
                    android:id="@+id/rbOnline"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_input_field"
                    android:buttonTint="@color/accent_tech"
                    android:paddingHorizontal="12dp"
                    android:text="Thanh toán Online (Thẻ/Ví)"
                    android:textColor="@color/white_tech"
                    android:textSize="15sp" />
            </RadioGroup>

            <!-- Section: Tóm tắt -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="#0DFFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tiền hàng"
                            android:textColor="@color/gray_tech_text"
                            android:textSize="15sp" />
                        <TextView
                            android:id="@+id/tvMethodTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="0 VNĐ"
                            android:textColor="@color/white_tech"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Phí vận chuyển"
                            android:textColor="@color/gray_tech_text"
                            android:textSize="15sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="Miễn phí"
                            android:textColor="@color/accent_tech"
                            android:textSize="15sp" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="16dp"
                        android:background="#1AFFFFFF" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TỔNG CỘNG"
                            android:textColor="@color/white_tech"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvTotalPricePayment"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="0 VNĐ"
                            android:textColor="@color/accent_tech"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutBottomPayment"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@color/black_tech_card"
        android:paddingHorizontal="20dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnConfirmPayment"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_accent_gradient"
            app:backgroundTint="@null"
            android:text="XÁC NHẬN ĐẶT HÀNG"
            android:textColor="@color/black_tech_bg"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            app:cornerRadius="14dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>